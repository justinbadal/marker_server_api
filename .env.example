# API Configuration
# Port exposed by the FastAPI backend on the host and used by the Web UI when building its default API endpoint.
MARKER_API_PORT=8336
# Port exposed by the Next.js Web UI on the host.
MARKER_WEBUI_PORT=3005
# Port exposed by the Caddy reverse proxy on the host. This becomes the single public entrypoint for both UI and API.
MARKER_PROXY_PORT=8048
# Hostname or IP address clients should use to reach this server from the browser.
MARKER_SERVER_IP=localhost
# Bearer token required by the backend API and entered in the Web UI connection panel.
MARKER_API_TOKEN=change-me

# Host Paths
# Windows host directory where Marker output folders are persisted and mounted into the API container.
HOST_OUTPUT_DIR=C:\coding\marker_output
# Windows host directory used to persist Hugging Face and model cache data across container restarts.
HOST_MODEL_CACHE_DIR=C:\Users\YourUser\.cache\huggingface

# LLM Configuration
# OpenAI-compatible endpoint used by Marker for LLM-assisted processing steps.
OPENAI_BASE_URL=http://host.docker.internal:8020/v1
# Model identifier passed to Marker for LLM-assisted text extraction and cleanup.
OPENAI_MODEL=openai/gpt-oss-20b

# Synology SSH Integration
# Synology NAS hostname or IP used for SSH/SFTP uploads after conversion completes.
SYNOLOGY_SSH_HOST=10.0.1.41
# SSH port on the Synology NAS. Standard SSH uses 22.
SYNOLOGY_SSH_PORT=22
# NAS username that owns the target folder and has SSH/SFTP access.
SYNOLOGY_SSH_USER=justin
# In-container path to the private SSH key used by the API container to authenticate to Synology.
SYNOLOGY_SSH_KEY_PATH=/run/secrets/marker_server_api_synology_key
# Optional passphrase for the SSH private key. Leave blank when the key is unencrypted.
SYNOLOGY_SSH_KEY_PASSPHRASE=
# Base directory on the NAS where each processed document gets its own folder.
SYNOLOGY_SSH_REMOTE_BASE_PATH=/homes/justin/RAG/Marker
# In-container path to the known_hosts file used for strict host verification of the NAS SSH host key.
SYNOLOGY_SSH_KNOWN_HOSTS_PATH=/run/secrets/marker_server_api_synology_known_hosts
# Set to true only if you intentionally want the container to trust unknown SSH host keys automatically.
SYNOLOGY_SSH_AUTO_ADD_HOST_KEY=false
# Windows host path to the private SSH key file mounted read-only into the API container.
SYNOLOGY_SSH_KEY_SOURCE=C:/coding/marker_server_api_synology_key
# Windows host path to the known_hosts file mounted read-only into the API container.
SYNOLOGY_SSH_KNOWN_HOSTS_SOURCE=C:/coding/marker_server_api_synology_known_hosts
